<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Stock Market Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
margin:0;
font-family:Arial;
background:#0f172a;
color:white;
}

/* Sidebar */

.sidebar{
width:220px;
height:100vh;
background:#020617;
position:fixed;
padding-top:20px;
}

.sidebar h2{
text-align:center;
color:#22c55e;
}

.sidebar a{
display:block;
color:white;
padding:15px;
text-decoration:none;
}

.sidebar a:hover{
background:#1e293b;
}

/* Main */

.main{
margin-left:220px;
padding:20px;
}

/* Navbar */

.navbar{
background:#111827;
padding:15px;
border-radius:10px;
margin-bottom:20px;
}

/* Cards */

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:20px;
}

.card{
background:#1e293b;
padding:20px;
border-radius:10px;
box-shadow:0 4px 15px rgba(0,0,0,0.5);
}

.green{color:#22c55e;}
.red{color:#ef4444;}

/* Table */

table{
width:100%;
border-collapse:collapse;
background:#1e293b;
border-radius:10px;
overflow:hidden;
}

th,td{
padding:12px;
text-align:center;
}

th{
background:#020617;
}

tr:hover{
background:#334155;
}

/* Chart */

.chart{
background:#1e293b;
padding:20px;
border-radius:10px;
margin-top:20px;
}

</style>
</head>

<body>

<div class="sidebar">
<h2>StockPro</h2>

<a href="#">Dashboard</a>
<a href="#">Portfolio</a>
<a href="#">Market</a>
<a href="#">Analytics</a>
<a href="#">News</a>
<a href="#">Settings</a>

</div>


<div class="main">

<div class="navbar">
<h2>📈 Stock Market Dashboard</h2>
</div>


<div class="cards">

<div class="card">
<h3>NIFTY 50</h3>
<h2 class="green">22,450 ▲</h2>
<p>+1.25%</p>
</div>

<div class="card">
<h3>SENSEX</h3>
<h2 class="red">73,890 ▼</h2>
<p>-0.35%</p>
</div>

<div class="card">
<h3>Portfolio Value</h3>
<h2>₹5,20,000</h2>
<p class="green">+₹12,500 Today</p>
</div>

<div class="card">
<h3>Top Gainer</h3>
<h2 class="green">TCS</h2>
<p>+3.2%</p>
</div>

</div>


<h3>Market Watch</h3>

<table>

<tr>
<th>Stock</th>
<th>Price</th>
<th>Change</th>
<th>Volume</th>
</tr>

<tr>
<td>Reliance</td>
<td>₹2,850</td>
<td class="green">+1.8%</td>
<td>2.1M</td>
</tr>

<tr>
<td>TCS</td>
<td>₹3,620</td>
<td class="green">+3.2%</td>
<td>1.3M</td>
</tr>

<tr>
<td>Infosys</td>
<td>₹1,520</td>
<td class="red">-0.8%</td>
<td>900K</td>
</tr>

<tr>
<td>HDFC</td>
<td>₹1,640</td>
<td class="green">+0.6%</td>
<td>700K</td>
</tr>

</table>


<div class="chart">

<h3>Stock Price Chart</h3>

<canvas id="stockChart"></canvas>

</div>

</div>


<script>

const ctx=document.getElementById("stockChart");

new Chart(ctx,{
type:'line',

data:{
labels:["Mon","Tue","Wed","Thu","Fri"],

datasets:[{
label:"NIFTY Trend",

data:[22000,22150,22080,22300,22450],

borderColor:"#22c55e",

backgroundColor:"rgba(34,197,94,0.3)",

tension:0.4
}]
},

options:{
plugins:{
legend:{
labels:{color:"white"}
}
},

scales:{
x:{ticks:{color:"white"}},
y:{ticks:{color:"white"}}
}
}

});

</script>

</body>
</html>
